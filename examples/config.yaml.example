# yaml-language-server: $schema=https://raw.githubusercontent.com/not-hanjo-mei/ezyapper/main/examples/config.schema.json
# EZyapper config example (v3 grouped schema)
# ------------------------------------------------
# Copy this file to config.yaml and fill in your values.
# ALL fields shown here are required unless marked "optional override".
# Missing any required field = bot refuses to start.
#
# Quick start:
# 1) Fill core.discord + core.ai first
# 2) Choose memory mode:
#    - OFF: memory_pipeline.memory.retrieval.top_k=0 and consolidation.enabled=false
#    - ON: set embedding + qdrant + retrieval/consolidation
# 3) Enable optional modules in operations.* as needed

schema_version: 3

core:
  # ── Discord Bot Settings ──────────────────────────────
  discord:
    # Discord bot token from Developer Portal:
    # https://discord.com/developers/applications
    token: "YOUR_DISCORD_BOT_TOKEN"

    # Bot display name used in prompts and logs.
    bot_name: "EZyapper"

    # Bot user ID. Used to identify self-messages.
    # Required when memory consolidation is enabled.
    own_bot_id: "YOUR_BOT_USER_ID"

    # Random reply probability when bot is NOT mentioned (0.0-1.0).
    reply_percentage: 0.15

    # Minimum seconds between replies for the same user+channel.
    cooldown_seconds: 5

    # Hard cap: max responses per minute across all channels.
    max_responses_per_minute: 10

    # Whether to respond to messages from other bots.
    reply_to_bots: false

    # ── Rate limit window settings ──
    rate_limit:
      # Window size for per-user rate limiting (seconds).
      reset_period_seconds: 60

    # ── Behavior tuning ──
    # Timeout for consolidation-triggered response generation (seconds).
    consolidation_timeout_sec: 300

    # Interval between typing indicator updates (seconds).
    typing_indicator_interval_sec: 5

    # Delay before sending a response flagged as "long" (milliseconds).
    long_response_delay_ms: 500

    # Delay between sending each chunk of a split response (seconds).
    chunk_split_delay_sec: 2

    # Character limit for reply truncation (Discord max: 2000).
    reply_truncation_length: 2000

    # TTL for cached Discord image data (minutes).
    image_cache_ttl_min: 60

    # Max number of images kept in the in-memory cache.
    image_cache_max_entries: 100

  # ── AI / LLM Settings ─────────────────────────────────
  ai:
    # OpenAI-compatible API endpoint.
    # Examples:
    #   https://api.openai.com/v1
    #   http://127.0.0.1:3000/v1
    api_base_url: "https://api.openai.com/v1"

    api_key: "YOUR_API_KEY"

    # Main text model.
    model: "gpt-4o-mini"

    # Model used for multimodal/hybrid vision path.
    # Required when vision.mode is not text_only.
    vision_model: "gpt-4o"

    # Whether to fetch images and send them as base64 payloads.
    # Set false to send images as URLs (may not work with local endpoints).
    vision_base64: true

    # ── Vision processing ──
    vision:
      # text_only: ignore images
      # hybrid: describe image -> send text to main model
      # multimodal: send images directly to model
      mode: "text_only"

      # Prompt used to describe images in "hybrid" mode.
      # Required when mode is "hybrid".
      # description_prompt: "Describe this image in 1-2 sentences. Be compact but informative."

      # Max images consumed from one incoming message.
      # Required when mode is not text_only.
      max_images: 1

      # ── Optional: separate vision endpoint ──
      # Leave empty to inherit from ai.api_base_url / ai.api_key above.
      ## api_base_url: "https://api.openai.com/v1"
      ## api_key: "YOUR_API_KEY"
      ## max_tokens: 1024
      ## temperature: 0.8
      ## retry_count: 3
      ## timeout: 30
      ## extra_params: {}

    # ── Response tuning ──
    # Token limit for main chat completion responses.
    max_tokens: 4096

    # 0.0-2.0. Higher = more creative, lower = more deterministic.
    temperature: 0.8

    # Retries for transient API/network errors.
    retry_count: 3

    # Per-request LLM timeout (seconds).
    timeout: 180

    # HTTP client timeout for API connections (seconds).
    http_timeout_sec: 30

    # Max tool-calling iterations in a single conversation turn.
    # Guards against infinite tool-call loops.
    max_tool_iterations: 5

    # Max bytes for an image fetched from Discord CDN.
    max_image_bytes: 10485760

    # User-Agent header sent when fetching images from Discord.
    user_agent: "EZyapper/1.0"

    # If true, rejects image responses that lack a Content-Type header.
    require_image_content_type: false

    # System prompt template. Supports these variables:
    # {BotName}, {AuthorName}, {ServerName}, {GuildID}, {ChannelID}
    system_prompt: |
      You are {BotName}, a helpful Discord bot in the {ServerName} server.
      You're chatting with {AuthorName}.

      IMPORTANT CONTEXT:
      - Guild ID (Server ID): {GuildID}
      - Channel ID: {ChannelID}

      When using tools, ALWAYS use these exact IDs:
      - For server-wide tools: use GuildID: {GuildID}
      - For channel-specific tools: use ChannelID: {ChannelID}
      - Do NOT use names - use the numeric IDs provided above.

      Guidelines:
      - Be natural and conversational
      - Keep responses concise (under 200 words typically)
      - You have access to Discord tools. Use them when appropriate.

    # ── Optional: extra parameters forwarded to the API ──
    ## extra_params: {}

  # ── Decision Classifier ───────────────────────────────
  # When enabled, an LLM decides whether the bot should respond.
  # Disable if you want simple mention/percentage-based replies.
  decision:
    enabled: false

    # All fields below are required ONLY when enabled: true.
    ## model: "gpt-4o-mini"
    ## api_base_url: "https://api.openai.com/v1"
    ## api_key: "YOUR_DECISION_API_KEY"
    ## max_tokens: 64
    ## temperature: 0.1
    ## retry_count: 3
    ## timeout: 10
    ## http_timeout_sec: 30
    ## system_prompt: |
    ##   You are a decision classifier for a Discord bot. Decide if the bot should respond.
    ##   Respond ONLY with valid JSON: {"should_respond": true/false, "reason": "...", "confidence": 0.0-1.0}
    ## extra_params: {}

memory_pipeline:
  # ── Embedding Model ───────────────────────────────────
  embedding:
    # Optional override: separate embedding endpoint.
    # Leave empty to inherit from core.ai.api_base_url / core.ai.api_key.
    ## api_base_url: "https://api.openai.com/v1"
    ## api_key: "YOUR_API_KEY"

    # Embedding model for vector search and consolidation.
    # Required when memory retrieval or consolidation is enabled.
    model: "text-embedding-3-small"

    # Retries for embedding API calls.
    retry_count: 1

    # Per-request embedding timeout (seconds).
    timeout: 10

    # ── Optional: extra parameters ──
    ## extra_params: {}

  # ── Memory Settings ───────────────────────────────────
  memory:
    # Trigger consolidation every N bot-handled messages.
    consolidation_interval: 50

    # Number of recent messages to pull as short-term context.
    short_term_limit: 20

    # Pagination limit for fetching older messages.
    max_paginated_limit: 100

    # ── Retry settings for Qdrant operations ──
    # Base delay for exponential backoff (milliseconds).
    retry_base_delay_ms: 1000

    # Max delay for exponential backoff (milliseconds).
    retry_max_delay_ms: 30000

    # Max retry attempts for Qdrant operations.
    max_retries: 3

    # ── Semantic Retrieval ──
    retrieval:
      # Number of memories returned per retrieval query.
      # Set to 0 to disable long-term memory retrieval.
      top_k: 5

      # Similarity score threshold (0.0-1.0).
      # Memories below this score are filtered out.
      min_score: 0.75

      # Default top_k used when the caller doesn't specify one.
      default_top_k: 5

      # Default min_score used when the caller doesn't specify one.
      default_min_score: 0.75

    # ── Memory Consolidation ──
    consolidation:
      # Enable writing new long-term memories.
      enabled: false

      # All fields below are required ONLY when enabled: true.
      ## model: "gpt-4o-mini"
      ## api_base_url: "https://api.openai.com/v1"      # optional override
      ## api_key: "YOUR_API_KEY"                        # optional override
      ## max_tokens: 4096
      ## temperature: 0.8
      ## retry_count: 5
      ## timeout: 30

      # ── Optional: separate vision settings for consolidation ──
      ## vision_model: "gpt-4o"
      ## vision_base64: true
      ## vision_api_base_url: "https://api.openai.com/v1"
      ## vision_api_key: "YOUR_API_KEY"
      ## vision_max_tokens: 1024
      ## vision_temperature: 0.8
      ## vision_retry_count: 5
      ## vision_timeout: 30

      # How many existing memories to search for deduplication/similarity.
      memory_search_limit: 20

      # Size of the internal worker queue for consolidation jobs.
      worker_queue_size: 10

      # ── Optional: extra parameters ──
      ## extra_params: {}

      # Consolidation system prompt. Required when enabled.
      ## system_prompt: |
      ##   Extract memorable information about USERS from this conversation.
      ##   Return JSON array: [{"user_id": "...", "memories": [{"content": "...", "type": "fact|episode", "confidence": 0.0-1.0, "keywords": []}]}]

  # ── Qdrant Vector Database ────────────────────────────
  qdrant:
    # Qdrant host. Use "localhost" for local, container name for Docker.
    host: "localhost"

    # Qdrant gRPC port (default: 6334).
    port: 6334

    # Optional API key for cloud/secured Qdrant instances.
    ## api_key: "YOUR_QDRANT_API_KEY"

    # Vector dimensions. Must match your embedding model:
    # text-embedding-3-small / text-embedding-ada-002 -> 1536
    # text-embedding-3-large                         -> 3072
    vector_size: 1536

access_control:
  # ── Blacklist ─────────────────────────────────────────
  # Block specific users, channels, or guilds.
  # Cannot be combined with whitelist for the same category.
  blacklist:
    users: []
    guilds: []
    channels: []

  # ── Whitelist ─────────────────────────────────────────
  # When set, bot ONLY responds in listed users/channels/guilds.
  # Cannot be combined with blacklist for the same category.
  whitelist:
    users: []
    guilds: []
    channels: []

operations:
  # ── Web Dashboard ─────────────────────────────────────
  web:
    enabled: false

    # All fields below are required ONLY when enabled: true.
    ## port: 8080
    ## username: "admin"
    ## password: "CHANGE_ME"
    ## memories_page_limit: 50
    ## content_truncation_length: 500
    ## session_ttl_min: 30
    ## session_cleanup_interval_min: 5
    ## stats_query_timeout_sec: 5
    ## log_default_lines: 100
    ## log_max_lines: 1000
    ## log_max_read_bytes: 1048576

  # ── Logging ───────────────────────────────────────────
  logging:
    # Log level: debug, info, warn, error.
    level: "info"

    # Log file path.
    file: "logs/ezyapper.log"

    # Max log file size before rotation (megabytes).
    max_size: 100

    # Number of rotated backup files to keep.
    max_backups: 3

    # Retention for rotated logs (days).
    max_age: 30

  # ── Plugin System ─────────────────────────────────────
  plugins:
    enabled: false

    # All fields below are required ONLY when enabled: true.
    ## plugins_dir: "plugins"
    ## default_tool_timeout_ms: 30000
    ## startup_timeout_sec: 90
    ## rpc_timeout_sec: 5
    ## before_send_timeout_sec: 180
    ## command_timeout_sec: 45
    ## shutdown_timeout_sec: 5
    ## disable_timeout_sec: 2

  # ── MCP Client ────────────────────────────────────────
  mcp:
    enabled: false

    # All fields below are required ONLY when enabled: true.
    # Servers can use either "stdio" or "sse" transport.
    servers: []
    # Example server list:
    # servers:
    #   - name: datetime
    #     type: stdio
    #     command: npx
    #     args: ["-y", "@pinkpixel/datetime-mcp"]
    #     env:
    #       "TZ": "UTC"
    #   - name: remote-tool
    #     type: sse
    #     url: "http://localhost:8080/sse"

  # ── Operational Settings ──────────────────────────────
  operations:
    # Graceful shutdown grace period (seconds).
    shutdown_timeout_sec: 300

    # Interval for periodic cleanup tasks (minutes).
    cleanup_interval_min: 5
