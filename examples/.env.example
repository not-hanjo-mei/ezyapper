# EZyapper Environment Variables
# ================================
# Copy this file to .env and fill in your values
# All variables use EZYAPPER_ prefix (handled by Viper)
#
# NOTE: This bot has NO DEFAULT VALUES. You MUST configure all required fields
# in config.yaml or via environment variables below, or the bot will exit on startup.

# ===========================================
# REQUIRED - Bot will not start without these
# ===========================================

# Discord Bot Token
# Get it from: https://discord.com/developers/applications
EZYAPPER_DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# AI/LLM API Key
EZYAPPER_AI_API_KEY=YOUR_API_KEY_HERE

# ===========================================
# AI/LLM Configuration (Optional)
# Falls back to config.yaml values if not set
# ===========================================

# Main chat model
EZYAPPER_AI_API_BASE_URL=https://api.openai.com/v1
# EZYAPPER_AI_MODEL=gpt-4o-mini
# EZYAPPER_AI_MAX_TOKENS=1024
# EZYAPPER_AI_TEMPERATURE=0.8
# EZYAPPER_AI_RETRY_COUNT=3
# EZYAPPER_AI_TIMEOUT=30

# Vision model for image processing
# EZYAPPER_AI_VISION_MODEL=gpt-4o
# EZYAPPER_AI_VISION_BASE64=false
# EZYAPPER_AI_VISION_MODE=multimodal
# EZYAPPER_AI_VISION_MAX_IMAGES=4
# EZYAPPER_AI_VISION_DESCRIPTION_PROMPT=Describe this image in 1-2 sentences.
# EZYAPPER_AI_VISION_API_BASE_URL=
# EZYAPPER_AI_VISION_API_KEY=
# EZYAPPER_AI_VISION_MAX_TOKENS=
# EZYAPPER_AI_VISION_TEMPERATURE=
# EZYAPPER_AI_VISION_RETRY_COUNT=
# EZYAPPER_AI_VISION_TIMEOUT=

# ===========================================
# Embedding Configuration (Optional)
# Used for vector memory storage
# ===========================================

# EZYAPPER_EMBEDDING_API_BASE_URL=
# EZYAPPER_EMBEDDING_API_KEY=
# EZYAPPER_EMBEDDING_MODEL=text-embedding-3-small
# EZYAPPER_EMBEDDING_RETRY_COUNT=3
# EZYAPPER_EMBEDDING_TIMEOUT=30

# ===========================================
# Memory Configuration (Optional)
# ===========================================

# EZYAPPER_MEMORY_CONSOLIDATION_INTERVAL=50
# EZYAPPER_MEMORY_SHORT_TERM_LIMIT=20

# Consolidation text model (defaults to ai.* values)
# EZYAPPER_MEMORY_CONSOLIDATION_ENABLED=true
# EZYAPPER_MEMORY_CONSOLIDATION_MAX_MESSAGES=20
# EZYAPPER_MEMORY_CONSOLIDATION_MODEL=
# EZYAPPER_MEMORY_CONSOLIDATION_API_BASE_URL=
# EZYAPPER_MEMORY_CONSOLIDATION_API_KEY=
# EZYAPPER_MEMORY_CONSOLIDATION_MAX_TOKENS=
# EZYAPPER_MEMORY_CONSOLIDATION_TEMPERATURE=
# EZYAPPER_MEMORY_CONSOLIDATION_RETRY_COUNT=
# EZYAPPER_MEMORY_CONSOLIDATION_TIMEOUT=

# Consolidation vision model (defaults to ai.vision.* or ai.*)
# EZYAPPER_MEMORY_CONSOLIDATION_VISION_MODEL=
# EZYAPPER_MEMORY_CONSOLIDATION_VISION_API_BASE_URL=
# EZYAPPER_MEMORY_CONSOLIDATION_VISION_API_KEY=
# EZYAPPER_MEMORY_CONSOLIDATION_VISION_MAX_TOKENS=
# EZYAPPER_MEMORY_CONSOLIDATION_VISION_TEMPERATURE=
# EZYAPPER_MEMORY_CONSOLIDATION_VISION_RETRY_COUNT=
# EZYAPPER_MEMORY_CONSOLIDATION_VISION_TIMEOUT=

# Memory retrieval settings
# EZYAPPER_MEMORY_RETRIEVAL_TOP_K=5
# EZYAPPER_MEMORY_RETRIEVAL_MIN_SCORE=0.75
# EZYAPPER_MEMORY_RETRIEVAL_TIME_DECAY_ENABLED=true

# ===========================================
# Qdrant Configuration (Optional)
# Vector database for long-term memory
# ===========================================

# EZYAPPER_QDRANT_HOST=qdrant
# EZYAPPER_QDRANT_PORT=6334
# EZYAPPER_QDRANT_API_KEY=
# EZYAPPER_QDRANT_VECTOR_SIZE=1536

# ===========================================
# Discord Settings (Optional)
# ===========================================

# EZYAPPER_DISCORD_BOT_NAME=EZyapper
# EZYAPPER_DISCORD_REPLY_PERCENTAGE=0.15
# EZYAPPER_DISCORD_COOLDOWN_SECONDS=5
# EZYAPPER_DISCORD_MAX_RESPONSES_PER_MINUTE=10

# ===========================================
# Blacklist & Whitelist (Optional)
# Configure in config.yaml (list-type values)
# Note: Cannot use both blacklist and whitelist for same category
# ===========================================

# ===========================================
# WebUI Configuration (Optional)
# ===========================================

# EZYAPPER_WEB_PORT=8080
# EZYAPPER_WEB_USERNAME=admin
# EZYAPPER_WEB_PASSWORD=changeme123
# EZYAPPER_WEB_ENABLED=true

# ===========================================
# Logging Configuration (Optional)
# ===========================================

# EZYAPPER_LOGGING_LEVEL=info
# EZYAPPER_LOGGING_FILE=logs/ezyapper.log
# EZYAPPER_LOGGING_MAX_SIZE=100
# EZYAPPER_LOGGING_MAX_BACKUPS=3
# EZYAPPER_LOGGING_MAX_AGE=30

# ===========================================
# Decision Service (Optional)
# LLM-based reply decisions
# ===========================================

# EZYAPPER_DECISION_ENABLED=false
# EZYAPPER_DECISION_MODEL=
# EZYAPPER_DECISION_API_BASE_URL=
# EZYAPPER_DECISION_API_KEY=
# EZYAPPER_DECISION_MAX_TOKENS=1024
# EZYAPPER_DECISION_TEMPERATURE=0.1
# EZYAPPER_DECISION_TIMEOUT=15
# EZYAPPER_DECISION_FALLBACK_PERCENTAGE=0.2
# EZYAPPER_DECISION_CONTEXT_MESSAGES=5

# ===========================================
# Plugin Settings (Optional)
# ===========================================

# EZYAPPER_PLUGINS_ENABLED=true
# EZYAPPER_PLUGINS_PLUGINS_DIR=plugins

# ===========================================
# Docker-specific (not used by app directly)
# ===========================================

TZ=UTC
