{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/not-hanjo-mei/ezyapper/main/examples/plugin.schema.json",
  "title": "EZyapper Plugin Manifest",
  "description": "JSON Schema for plugin.json manifest files (command and JSON-RPC runtimes)",
  "type": "object",
  "required": ["$schema", "runtime", "name", "version", "author", "description", "priority", "tools"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string", "format": "uri" },
    "runtime": { "type": "string", "enum": ["jsonrpc", "command"] },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "author": { "type": "string" },
    "description": { "type": "string" },
    "priority": { "type": "integer" },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description", "parameters"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "parameters": { "type": "object", "additionalProperties": true },
          "command": { "type": "string" },
          "args": { "type": "array", "items": { "type": "string" } },
          "arg_keys": { "type": "array", "items": { "type": "string" } },
          "timeout_ms": { "type": "integer", "minimum": 0, "maximum": 300000 }
        }
      }
    }
  }
}
